{
  "Env": {},
  "Git": {
    "URI": "https://github.com/bringauto/numa-cmake-build.git",
    "Revision": "init"
  },
  "Build": {
    "CMake": {
      "Defines": {
        "CMAKE_BUILD_TYPE": "Release",
        "NUMACTL_VERSION": "2.0.19"
      }
    }
